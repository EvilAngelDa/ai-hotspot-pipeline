<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.ai-hotspot-pipeline</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>__INSTALL_DIR__/scripts/run_pipeline.sh</string>
  </array>
  <key>WorkingDirectory</key>
  <string>__INSTALL_DIR__</string>
  <key>StartCalendarInterval</key>
  <dict>
    <key>Hour</key>
    <integer>9</integer>
    <key>Minute</key>
    <integer>0</integer>
  </dict>
  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>__HOME__/.local/bin:__HOME__/.cargo/bin:/usr/local/bin:/usr/bin:/bin</string>
    <key>TZ</key>
    <string>Asia/Shanghai</string>
    <key>HOME</key>
    <string>__HOME__</string>
    <key>TRENDRADAR_ROOT</key>
    <string>__HOME__/tools/TrendRadar</string>
  </dict>
  <key>StandardOutPath</key>
  <string>__INSTALL_DIR__/logs/launchd.out.log</string>
  <key>StandardErrorPath</key>
  <string>__INSTALL_DIR__/logs/launchd.err.log</string>
  <key>RunAtLoad</key>
  <false/>
</dict>
</plist>
